#------------------------------------------------------------------
quit-after-last-window-closed = true
window-save-state = always
window-padding-balance = true
window-colorspace = display-p3
macos-titlebar-proxy-icon = hidden
#----------------------------------------------------quick_terminal
quick-terminal-position = bottom
quick-terminal-screen = main
quick-terminal-size = 40%
#---------------------------------------------------------clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
#------------------------------------------------------------------
bell-features = no-attention
shell-integration = zsh
shell-integration-features = no-cursor,sudo,title,ssh-env,ssh-terminfo,path
cursor-click-to-move = true
mouse-hide-while-typing = true
#------------------------------------------------------------------
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true
#------------------------------------------------------------------
keybind = global:opt+tab=toggle_quick_terminal
#--------------------------------------------------------goto_split
keybind = unconsumed:opt+control+h=goto_split:left
keybind = unconsumed:opt+control+j=goto_split:bottom
keybind = unconsumed:opt+control+k=goto_split:top
keybind = unconsumed:opt+control+l=goto_split:right
#------------------------------------------------------------------
keybind = unconsumed:opt+cmd+Equal=equalize_splits
#--------------------------------------------------------appearance
font-size = 15
theme = light:Oxocarbon-light,dark:Oxocarbon-dark
cursor-style = underline
